{
  "name": "@h-wb/sync-anilist",
  "version": "1.0.0",
  "description": "Codex plugin to sync manga reading progress to AniList, with per-series volume/chapter routing via notes and reread (REPEATING) detection",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h-wb/sync-anilist.git"
  },
  "homepage": "https://github.com/h-wb/sync-anilist#readme",
  "bugs": {
    "url": "https://github.com/h-wb/sync-anilist/issues"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/index.js --sourcemap --banner:js='#!/usr/bin/env node'",
    "dev": "npm run build -- --watch",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "check": "biome check . && tsc --noEmit",
    "prepublishOnly": "npm run check && npm run test && npm run build"
  },
  "keywords": [
    "codex",
    "plugin",
    "anilist",
    "sync",
    "manga",
    "reading-progress",
    "reread"
  ],
  "author": "h-wb",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@ashdev/codex-plugin-sdk": "^1.34.1",
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
