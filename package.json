{
  "name": "codex-plugins",
  "version": "0.0.0",
  "private": true,
  "description": "A collection of custom Codex plugins (AniList sync, MangaBaka metadata).",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h-wb/codex-plugins.git"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "check": "biome check . && npm run typecheck"
  },
  "keywords": [
    "codex",
    "plugin",
    "manga"
  ],
  "author": "h-wb",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
