{
  "name": "@h-wb/metadata-mangabaka",
  "version": "1.0.0",
  "description": "MangaBaka metadata provider for Codex with per-edition Collection support (match volume counts to the edition you actually own)",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h-wb/codex-plugins.git",
    "directory": "packages/metadata-mangabaka"
  },
  "homepage": "https://github.com/h-wb/codex-plugins/tree/main/packages/metadata-mangabaka#readme",
  "bugs": {
    "url": "https://github.com/h-wb/codex-plugins/issues"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/index.js --sourcemap --banner:js='#!/usr/bin/env node'",
    "dev": "npm run build -- --watch",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "check": "biome check . && tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "codex",
    "plugin",
    "mangabaka",
    "manga",
    "metadata",
    "collections",
    "editions"
  ],
  "author": "h-wb",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@ashdev/codex-plugin-sdk": "^1.35.0"
  }
}
